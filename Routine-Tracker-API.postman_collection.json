    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get All Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/todos/get",
              "host": ["{{baseUrl}}"],
              "path": ["todos", "get"]
            }
          }
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has task object', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('id');",
                  "    pm.expect(jsonData.data).to.have.property('title');",
                  "});",
                  "",
                  "pm.test('Save task ID for later use', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('taskId', jsonData.data.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"title\\\": \\\"Learn TypeScript\\\",\\n  \\\"taskDescription\\\": \\\"Complete TypeScript course and advanced types\\\",\\n  \\\"completed\\\": false\\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/todos/post",
              "host": ["{{baseUrl}}"],
              "path": ["todos", "post"]
            }
          }
        },
        {
          "name": "Get Task by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has task object with correct ID', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('id');",
                  "    pm.expect(jsonData.data.id).to.equal(parseInt(pm.environment.get('taskId')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/todos/get/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["todos", "get", "{{taskId}}"]
            }
          }
        },
        {
          "name": "Update Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Update successful', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.message).to.include('updated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"title\\\": \\\"Master TypeScript\\\",\\n  \\\"completed\\\": true\\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/todos/update/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["todos", "update", "{{taskId}}"]
            }
          }
        },
        {
          "name": "Delete Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Delete successful', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/todos/delete/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["todos", "delete", "{{taskId}}"]
            }
          }
        }
      ]
